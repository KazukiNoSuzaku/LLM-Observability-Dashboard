# =============================================================================
# LLM Observability Dashboard — Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider (required for live generation via POST /api/v1/generate)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# -----------------------------------------------------------------------------
# Database
#
# Option A — SQLite (default, zero-config, great for local dev)
DATABASE_URL=sqlite+aiosqlite:///./llm_observability.db
#
# Option B — Supabase (PostgreSQL)
# 1. Create a project at https://supabase.com
# 2. Go to Project Settings → Database → Connection string → URI
# 3. Replace [password] with your database password
# DATABASE_URL=postgresql+asyncpg://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
#
# Option C — Self-hosted PostgreSQL
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/llm_observability
#
# Supabase project URL and anon key (only needed if you use the supabase-py
# client directly; the DATABASE_URL above is sufficient for SQLAlchemy)
# SUPABASE_URL=https://<ref>.supabase.co
# SUPABASE_ANON_KEY=your_anon_key_here

# -----------------------------------------------------------------------------
# Arize Phoenix tracing (optional — set PHOENIX_ENABLED=false to disable)
# Run Phoenix locally: python -c "import phoenix as px; px.launch_app()"
# Then visit http://localhost:6006 for the trace visualization UI.
# -----------------------------------------------------------------------------
PHOENIX_ENDPOINT=http://localhost:6006/v1/traces
PHOENIX_ENABLED=true

# -----------------------------------------------------------------------------
# LLM defaults
# -----------------------------------------------------------------------------
DEFAULT_MODEL=claude-haiku-4-5-20251001
MAX_TOKENS=1024

# -----------------------------------------------------------------------------
# FastAPI server
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# -----------------------------------------------------------------------------
# Alerting thresholds (logged as WARNING when breached)
# -----------------------------------------------------------------------------
LATENCY_ALERT_THRESHOLD_MS=5000.0
COST_ALERT_THRESHOLD_USD=0.10
