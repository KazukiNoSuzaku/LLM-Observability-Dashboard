# =============================================================================
# LLM Observability Dashboard — Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider (required for live generation via POST /api/v1/generate)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# -----------------------------------------------------------------------------
# Database
#
# Option A — SQLite (default, zero-config, great for local dev)
DATABASE_URL=sqlite+aiosqlite:///./llm_observability.db
#
# Option B — Supabase (PostgreSQL)
# 1. Create a project at https://supabase.com
# 2. Go to Project Settings → Database → Connection string → URI
# 3. Replace [password] with your database password
# DATABASE_URL=postgresql+asyncpg://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
#
# Option C — Self-hosted PostgreSQL
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/llm_observability
#
# Supabase project URL and anon key (only needed if you use the supabase-py
# client directly; the DATABASE_URL above is sufficient for SQLAlchemy)
# SUPABASE_URL=https://<ref>.supabase.co
# SUPABASE_ANON_KEY=your_anon_key_here

# -----------------------------------------------------------------------------
# Arize Phoenix tracing (optional — set PHOENIX_ENABLED=false to disable)
# Run Phoenix locally: python -c "import phoenix as px; px.launch_app()"
# Then visit http://localhost:6006 for the trace visualization UI.
# -----------------------------------------------------------------------------
PHOENIX_ENDPOINT=http://localhost:6006/v1/traces
PHOENIX_ENABLED=true

# -----------------------------------------------------------------------------
# LLM defaults
# -----------------------------------------------------------------------------
DEFAULT_MODEL=claude-haiku-4-5-20251001
MAX_TOKENS=1024

# -----------------------------------------------------------------------------
# FastAPI server
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# -----------------------------------------------------------------------------
# Alerting thresholds (logged as WARNING when breached)
# -----------------------------------------------------------------------------
LATENCY_ALERT_THRESHOLD_MS=5000.0
COST_ALERT_THRESHOLD_USD=0.10

# -----------------------------------------------------------------------------
# Webhook alerting channels (leave empty / commented out to disable)
# All channels are independent — enable any combination.
# -----------------------------------------------------------------------------
# Slack — https://api.slack.com/messaging/webhooks
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx

# Discord — Server Settings → Integrations → Webhooks
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# PagerDuty — Events API v2 routing key
# 1. In PagerDuty go to Services → <your service> → Integrations → Add integration
# 2. Choose "Events API v2", copy the 32-char Integration Key
# PAGERDUTY_ROUTING_KEY=your_32_char_routing_key_here

# Microsoft Teams — Incoming Webhook connector
# 1. In Teams open the channel → ... → Connectors → Incoming Webhook → Configure
# 2. Copy the generated webhook URL
# TEAMS_WEBHOOK_URL=https://<tenant>.webhook.office.com/webhookb2/...

# -----------------------------------------------------------------------------
# Safety & Guardrails
# -----------------------------------------------------------------------------
GUARDRAILS_ENABLED=true
GUARDRAILS_BLOCK_ON_PII=false
GUARDRAILS_BLOCK_ON_JAILBREAK=true
GUARDRAILS_REDACT_OUTPUT_PII=true
GUARDRAILS_USE_PRESIDIO=true

# NeMo Guardrails — dialogue-flow & topic rails (optional, off by default)
# Requires: pip install nemoguardrails langchain-openai
#           (or langchain-anthropic if using Anthropic for validation)
GUARDRAILS_NEMO_ENABLED=false
GUARDRAILS_NEMO_ENGINE=auto     # auto | openai | anthropic
GUARDRAILS_NEMO_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Authentication (disabled by default — set AUTH_ENABLED=true to require creds)
#
# Two mechanisms are supported and can be used independently or together:
#   1. Bearer token — POST /auth/token with username+password → JWT
#   2. API key     — X-API-Key: <key> request header (static secret)
#
# Quick start:
#   AUTH_ENABLED=true
#   AUTH_PASSWORD=changeme
#   (optionally) AUTH_API_KEY=my-static-key
# -----------------------------------------------------------------------------
AUTH_ENABLED=false

# Credentials for POST /auth/token (OAuth2 Password Flow)
AUTH_USERNAME=admin
AUTH_PASSWORD=

# Static API key alternative (X-API-Key header). Leave blank to disable.
AUTH_API_KEY=

# JWT signing secret. Derived from AUTH_PASSWORD when empty.
# Set explicitly in production so tokens survive server restarts.
AUTH_SECRET_KEY=

# Bearer token lifetime (minutes)
AUTH_TOKEN_EXPIRE_MINUTES=60

# -----------------------------------------------------------------------------
# OAuth2 Social Login (Google + GitHub)
#
# Tokens returned by /auth/google/callback and /auth/github/callback are the
# same JWT format as /auth/token — use them as Bearer tokens on /api/v1/*.
# Users are auto-provisioned in the oauth_users table on first login.
#
# Google setup:
#   1. https://console.cloud.google.com/apis/credentials
#   2. Create "OAuth 2.0 Client ID" (Web application)
#   3. Authorised redirect URI: {OAUTH_REDIRECT_BASE_URL}/auth/google/callback
#
# GitHub setup:
#   1. https://github.com/settings/developers → OAuth Apps → New OAuth App
#   2. Callback URL: {OAUTH_REDIRECT_BASE_URL}/auth/github/callback
# -----------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your_google_client_secret

# GITHUB_CLIENT_ID=your_github_oauth_app_client_id
# GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

# Base URL for OAuth2 redirect URIs (no trailing slash)
OAUTH_REDIRECT_BASE_URL=http://localhost:8000

# Secret for Starlette SessionMiddleware (CSRF state storage) — change in prod
OAUTH_SESSION_SECRET=change-me-in-production
